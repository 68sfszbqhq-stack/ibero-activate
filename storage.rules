rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de caminatas V2 - solo usuarios autenticados pueden subir/leer
    match /walking_v2_photos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Resto de archivos del proyecto
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
